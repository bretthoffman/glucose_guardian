{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx ./src/index.ts",
    "build": "pnpm --filter @workspace/api-zod run build && pnpm --filter @workspace/db run build && tsx ./build.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@workspace/db": "workspace:*",
    "@workspace/api-zod": "workspace:*",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "openai": "^4.100.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/express": "^5.0.6",
    "@types/cors": "^2.8.19",
    "@types/cookie-parser": "^1.4.10",
    "esbuild": "^0.27.3",
    "tsx": "catalog:"
  }
}
