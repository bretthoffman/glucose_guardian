# Convex deployment URL (required for doctor snapshots and doctor accounts)
CONVEX_URL=https://your-deployment.convex.cloud

# Snapshot ingest (mobile sync + doctorPortalState reads/writes via api.doctor.*)
# Must match the value in Convex dashboard → Settings → Environment Variables
CONVEX_DOCTOR_INGEST_SECRET=

# Doctor account auth + patient links (api.doctorAccounts.*)
# Must match the value in Convex dashboard → Settings → Environment Variables
# Use a DIFFERENT random string from CONVEX_DOCTOR_INGEST_SECRET
CONVEX_DOCTOR_API_SECRET=
