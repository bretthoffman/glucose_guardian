# Dev server (optional — defaults shown)
PORT=5173
BASE_PATH=/

# API URL for production / cross-origin deploy.
# When set, requests like /api/doctor/login are sent to:
#   ${VITE_API_BASE_URL}/api/doctor/login
# When unset, the app uses relative /api/... paths (same origin).
#
# Example:
# VITE_API_BASE_URL=https://api.example.com

# Local dev proxy target when VITE_API_BASE_URL is unset.
# Vite proxies /api/* to this host during `pnpm dev`.
VITE_API_PROXY_TARGET=http://localhost:3000
